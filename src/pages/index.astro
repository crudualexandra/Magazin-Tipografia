---
// Single page for the landing site.
// We use MainLayout for shared header/nav and compose sections with components.
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout>
  <main id="home">
    <Hero />

    <!-- Products / Categories -->
    <section id="produse" class="section">
      <div class="container">
        <header class="section__header">
          <h2 class="section__title">Ce găsești la noi</h2>
          <p class="section__subtitle">
            Sortiment pentru cumpărături rapide: alimente, băuturi și produse pentru casă.
          </p>
        </header>

        <div class="grid cards">
          <article class="card">
            <h3 class="card__title">Fructe & Legume</h3>
            <p class="card__text">
              Produse proaspete pentru salate, gătit și gustări.
            </p>
            <ul class="card__list">
              <li>• sezonier & variat</li>
              <li>• ideal pentru meniul zilnic</li>
            </ul>
          </article>

          <article class="card">
            <h3 class="card__title">Cereale & Conserve</h3>
            <p class="card__text">
              Tot ce trebuie pentru o bucătărie completă.
            </p>
            <ul class="card__list">
              <li>• paste, orez, hrișcă</li>
              <li>• conserve, sosuri</li>
            </ul>
          </article>

          <article class="card">
            <h3 class="card__title">Băuturi & Dulciuri</h3>
            <p class="card__text">
              De la sucuri la gustări pentru copii și familie.
            </p>
            <ul class="card__list">
              <li>• apă, sucuri, ceai/cafea</li>
              <li>• biscuiți, bomboane</li>
            </ul>
          </article>

          <article class="card">
            <h3 class="card__title">Curățenie & Casă</h3>
            <p class="card__text">
              Produse pentru îngrijirea casei și rutina zilnică.
            </p>
            <ul class="card__list">
              <li>• detergenți & igienă</li>
              <li>• soluții pentru bucătărie/baie</li>
            </ul>
          </article>
        </div>

        <div class="ctaBanner">
          <div class="ctaBanner__text">
            <h3 class="ctaBanner__title">Ai nevoie de ceva anume?</h3>
            <p class="ctaBanner__subtitle">
              Scrie-ne pe WhatsApp și îți spunem rapid dacă este în stoc.
            </p>
          </div>
          <a
            class="btn btn--primary"
            href="https://wa.me/37379021721"
            target="_blank"
            rel="noopener noreferrer"
          >
            Întreabă pe WhatsApp
          </a>
        </div>
      </div>
    </section>

    <Features />

    <!-- Social proof -->
    <section id="recenzii" class="section">
      <div class="container">
        <header class="section__header">
          <h2 class="section__title">Ce spun clienții</h2>
          <p class="section__subtitle">
            Un magazin mic, dar cu grijă mare pentru oameni.
          </p>
        </header>

        <div class="grid testimonials">
          <figure class="quote">
            <blockquote class="quote__text">
              „Foarte comod — găsesc rapid tot ce-mi trebuie pentru acasă.”
            </blockquote>
            <figcaption class="quote__meta">
              <span class="stars" aria-label="5 stele">★★★★★</span>
              <span class="quote__name">Client din Nisporeni</span>
            </figcaption>
          </figure>

          <figure class="quote">
            <blockquote class="quote__text">
              „Prețuri bune și oamenii răspund repede la întrebări.”
            </blockquote>
            <figcaption class="quote__meta">
              <span class="stars" aria-label="5 stele">★★★★★</span>
              <span class="quote__name">Clientă</span>
            </figcaption>
          </figure>

          <figure class="quote">
            <blockquote class="quote__text">
              „Magazin de cartier, util — mai ales când ai nevoie de ceva urgent.”
            </blockquote>
            <figcaption class="quote__meta">
              <span class="stars" aria-label="5 stele">★★★★★</span>
              <span class="quote__name">Client</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- Team / About -->
    <section id="despre" class="section section--alt">
      <div class="container about">
        <div class="about__text">
          <h2 class="section__title">Despre noi</h2>
          <p class="section__subtitle">
            Magazin Tipografia este un business de familie din Nisporeni — construit pe
            ideea simplă: <strong>serviciu bun și produse necesare</strong>, zi de zi.
          </p>

          <ul class="checklist">
            <li>✔ Magazin alimentar cu sortiment variat</li>
            <li>✔ Produse pentru casă și curățenie</li>
            <li>✔ Comenzi/întrebări rapid pe WhatsApp & Facebook</li>
          </ul>

          <div class="about__actions">
            <a class="btn btn--primary" href="#contact">Contactează-ne</a>
            <a class="btn btn--ghost" href="#orar">Vezi orarul</a>
          </div>
        </div>

        <div class="about__panel" aria-label="Info rapid">
          <div class="infoBox">
            <h3 class="infoBox__title">Info rapid</h3>
            <dl class="infoBox__list">
              <div class="infoRow">
                <dt>Adresă</dt>
                <dd>Alexandru cel Bun 96, Nisporeni, Moldova, 6401</dd>
              </div>
              <div class="infoRow">
                <dt>Telefon</dt>
                <dd><a href="tel:+37379021721">+373 79 021 721</a></dd>
              </div>
              <div class="infoRow">
                <dt>WhatsApp</dt>
                <dd>
                  <a href="https://wa.me/37379021721" target="_blank" rel="noopener noreferrer">Scrie pe WhatsApp</a>
                </dd>
              </div>
              <div class="infoRow">
                <dt>Facebook</dt>
                <dd>
                  <a href="https://www.facebook.com/p/Magazin-Tipografia-100077701992519/" target="_blank" rel="noopener noreferrer">Pagina Facebook</a>
                </dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- Hours -->
    <section id="orar" class="section">
      <div class="container">
        <header class="section__header">
          <h2 class="section__title">Orar de lucru</h2>
          <p class="section__subtitle">
            Program (conform informației publice). Pentru confirmare, ne poți suna sau scrie pe Facebook, WhatsApp.
          </p>
        </header>

        <div class="hoursCard" aria-label="Tabel orar">
          <div class="hoursCard__top">
            <h3 class="hoursCard__title">Program săptămânal</h3>
          </div>

          <div class="hoursTable" role="table" aria-label="Orar săptămânal">
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Luni</div>
              <div class="hoursTime" role="cell">08:00 – 18:00</div>
            </div>
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Marți</div>
              <div class="hoursTime" role="cell">08:00 – 18:00</div>
            </div>
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Miercuri</div>
              <div class="hoursTime" role="cell">08:00 – 18:00</div>
            </div>
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Joi</div>
              <div class="hoursTime" role="cell">08:00 – 18:00</div>
            </div>
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Vineri</div>
              <div class="hoursTime" role="cell">08:00 – 18:00</div>
            </div>
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Sâmbătă</div>
              <div class="hoursTime" role="cell">08:00 – 16:00</div>
            </div>
            <div class="hoursRow" role="row">
              <div class="hoursDay" role="cell">Duminică</div>
              <div class="hoursTime" role="cell">08:00 – 13:00</div>
            </div>
          </div>

          <div class="hoursCard__cta">
            <a class="btn btn--ghost" href="tel:+37379021721">Sună pentru confirmare</a>
            <a class="btn btn--primary" href="#contact">Contact rapid</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="container">
        <header class="section__header">
          <h2 class="section__title">Întrebări frecvente</h2>
          <p class="section__subtitle">
            Răspunsuri rapide la cele mai comune întrebări.
          </p>
        </header>

        <div class="faq">
          <details class="faq__item" open>
            <summary class="faq__q">Pot întreba dacă un produs este în stoc?</summary>
            <p class="faq__a">
              Da. Cel mai simplu este pe WhatsApp: scrii produsul și cantitatea, iar noi îți răspundem.
            </p>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Vindeți doar produse alimentare?</summary>
            <p class="faq__a">
              Nu. Avem și produse pentru casă și curățenie (detergenți, soluții, consumabile).
            </p>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Cum ajung la magazin?</summary>
            <p class="faq__a">
              Ne găsești la: <strong>Alexandru cel Bun 96, Nisporeni</strong>. Pentru direcții rapide, sună-ne.
            </p>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Pot comanda pentru cineva din familie?</summary>
            <p class="faq__a">
              Sigur. Trimite lista pe WhatsApp și menționează numele persoanei care ridică.
            </p>
          </details>
        </div>

        <div class="centerCTA">
          <a class="btn btn--primary" href="https://wa.me/37379021721" target="_blank" rel="noopener noreferrer">
            Scrie acum pe WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section section--contact">
      <div class="container contact">
        <div class="contact__left">
          <h2 class="section__title">Contact</h2>
          <p class="section__subtitle">
            Întrebări, comenzi sau disponibilitate produse — contactează-ne rapid.
          </p>

          <div class="contactCards">
            <a class="contactCard" href="tel:+37379021721">
              <span class="contactCard__icon" aria-hidden="true">📞</span>
              <span class="contactCard__text">
                <span class="contactCard__title">Telefon</span>
                <span class="contactCard__value">+373 79 021 721</span>
              </span>
            </a>

            <a
              class="contactCard"
              href="https://wa.me/37379021721"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contactCard__icon" aria-hidden="true">💬</span>
              <span class="contactCard__text">
                <span class="contactCard__title">WhatsApp</span>
                <span class="contactCard__value">Scrie pentru stoc / întrebări</span>
              </span>
            </a>

            <a
              class="contactCard"
              href="https://www.facebook.com/p/Magazin-Tipografia-100077701992519/"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contactCard__icon" aria-hidden="true">📘</span>
              <span class="contactCard__text">
                <span class="contactCard__title">Facebook</span>
                <span class="contactCard__value">Vezi noutăți & postări</span>
              </span>
            </a>

            <div class="contactCard contactCard--static">
              <span class="contactCard__icon" aria-hidden="true">📍</span>
              <span class="contactCard__text">
                <span class="contactCard__title">Adresă</span>
                <span class="contactCard__value">
                  Alexandru cel Bun 96, Nisporeni, Moldova, 6401
                </span>
              </span>
            </div>

            <a class="contactCard" href="#orar">
              <span class="contactCard__icon" aria-hidden="true">🕒</span>
              <span class="contactCard__text">
                <span class="contactCard__title">Orar</span>
                <span class="contactCard__value">Vezi programul complet</span>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>
