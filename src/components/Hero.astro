---
// Hero section (migrated 1:1 from the previous HTML).
// Keep markup/classes identical so the existing CSS continues to work.
---

<section class="hero">
  <div class="container hero__grid">
    <div class="hero__content">
      <p class="hero__badge">🛒 Magazin local • Produse pentru fiecare zi</p>
      <h1 class="hero__title">
        Tot ce ai nevoie, <span class="hero__accent">aproape de casă</span>.
      </h1>
      <p class="hero__subtitle">
        Fructe și legume, cereale, băuturi, dulciuri și produse pentru curățenie —
        într-un singur loc, în Nisporeni.
      </p>

      <div class="hero__actions">
        <a class="btn btn--primary" href="#contact">Comandă / Întreabă</a>
        <a class="btn btn--ghost" href="#produse">Vezi ce găsești</a>
      </div>

      <ul class="hero__quick">
        <li>✅ Produse de bază zilnic</li>
        <li>✅ Prețuri corecte</li>
        <li>✅ Suport rapid pe WhatsApp si Facebook</li>
      </ul>
    </div>

    <div class="hero__card" aria-label="Card informativ">
      <div class="heroCard">
        <div class="heroCard__top">
          <div>
            <h2 class="heroCard__title">Magazin Tipografia</h2>
            <p class="heroCard__meta">Alexandru cel Bun 96, Nisporeni</p>
          </div>
          <span class="chip chip--open">Deschis</span>
        </div>

        <div class="heroCard__stats">
          <div class="stat">
            <span class="stat__k">🥦</span>
            <span class="stat__v">Legume & fructe</span>
          </div>
          <div class="stat">
            <span class="stat__k">🥫</span>
            <span class="stat__v">Cereale & conserve</span>
          </div>
          <div class="stat">
            <span class="stat__k">🧼</span>
            <span class="stat__v">Curățenie & casă</span>
          </div>
        </div>

        <div class="heroCard__actions">
          <a class="btn btn--small btn--primary" href="tel:+37379021721">Sună</a>
          <a
            class="btn btn--small btn--ghost"
            href="https://wa.me/37379021721"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
          <a
            class="btn btn--small btn--ghost"
            href="https://www.facebook.com/p/Magazin-Tipografia-100077701992519/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Facebook
          </a>
        </div>

        <div class="heroHours" aria-label="Orar scurt">
          <div class="heroHours__row">
            <span class="heroHours__k">Lun–Vin</span>
            <span class="heroHours__v">08:00 – 18:00</span>
          </div>
          <div class="heroHours__row">
            <span class="heroHours__k">Sâmbătă</span>
            <span class="heroHours__v">08:00 – 16:00</span>
          </div>
          <div class="heroHours__row">
            <span class="heroHours__k">Duminică</span>
            <span class="heroHours__v">08:00 – 13:00</span>
          </div>
          <a class="heroHours__link" href="#orar">Vezi orarul complet →</a>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__wave" aria-hidden="true"></div>
</section>
